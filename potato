function ap(){
  const sym=(document.getElementById('pt').value||'').trim().toUpperCase()+'.NS';
  const shares=parseInt(document.getElementById('ps').value)||0;
  const err=document.getElementById('pe');
  err.textContent='';
  if(!FB[sym]&&!liveStocks[sym]){err.textContent='Unknown ticker. Try: INFY, TCS, RELIANCE';return;}
  if(shares<1){err.textContent='Enter at least 1 share.';return;}
  const price=getPrice(sym);
  const cost=price*shares;
  if(cost>port.cash){err.textContent=`Not enough cash. Need ${fmt(cost)}, have ${fmt(port.cash)}`;return;}
  port.cash-=cost;
  const existing=port.pos.find(p=>p.sym===sym);
  if(existing){existing.shares+=shares;existing.invested+=cost;}
  else{port.pos.push({sym,shares,invested:cost});}
  const totalVal=port.cash+port.pos.reduce((a,p)=>a+getPrice(p.sym)*p.shares,0);
  port.hist.push({l:sym.replace('.NS',''),v:+totalVal.toFixed(0)});
  document.getElementById('pt').value='';
  savePort();
  renderPort();
}
function removePos(i){
  const p=port.pos[i];
  port.cash+=getPrice(p.sym)*p.shares;
  port.pos.splice(i,1);
  const totalVal=port.cash+port.pos.reduce((a,p)=>a+getPrice(p.sym)*p.shares,0);
  port.hist.push({l:'Sell',v:+totalVal.toFixed(0)});
  savePort();
  renderPort();
}

