// ===== SEEDED RNG & CHART DATA =====
function seededRng(seed){
  let s=seed;
  return function(){s=(s*9301+49297)%233280;return s/233280;};
}
// Date-aware seed: changes every 3 hours so charts refresh with new simulated data
function dateSeed(){
  const now=new Date();
  // Bucket time into 3-hour windows so seed changes every 3 hours
  const bucket=Math.floor(now.getTime()/(3*60*60*1000));
  return bucket;
}
function genPrices(sym,range){
  const base=getPrice(sym)||22000;
  const pct=getPct(sym)||0;
  const pts={'1W':7,'1M':30,'3M':90,'1Y':252}[range]||30;
  // Include date bucket in seed so prices change every 3 hours
  const symSeed=sym.split('').reduce((a,c)=>a+c.charCodeAt(0),0);
  const rng=seededRng(symSeed+pts+dateSeed());
  const prices=[];
  let p=base*(1-(pct/100)*0.8);
  for(let i=0;i<pts;i++){
    p=p*(1+(rng()-0.48)*0.018);
    prices.push(Math.max(1,+p.toFixed(2)));
  }
  prices.push(base);
  return prices;
}
// Cache for historical prices fetched from Yahoo
const histCache={};

async function fetchHistorical(sym, range){
  const key=sym+'_'+range;
  if(histCache[key]) return histCache[key];

  const intervalMap={'1W':'1day','1M':'1day','3M':'1day','1Y':'1week'};
  const sizeMap={'1W':7,'1M':30,'3M':90,'1Y':52};
  const interval=intervalMap[range]||'1day';
  const outputsize=sizeMap[range]||30;
  const tdSym=internalToTd(sym);

  try{
    const data = await workerFetch({
      action:'history',
      symbol: tdSym,
      interval,
      outputsize
    });

    if(data.status==='error' || !data.values || data.values.length<2) return null;

    const result = data.values.map(v=>({
      p: +parseFloat(v.close).toFixed(2),
      t: Math.floor(new Date(v.datetime).getTime()/1000)
    })).reverse(); // Twelve Data returns newest first

    histCache[key]=result;
    return result;
  } catch(e){
    console.warn('Historical fetch failed for', sym, e.message);
    return null;
  }
}

// Groq-powered forecast: generates 7-day forecast based on trend + news
async function genAIForecast(sym, lastPrice, pct, metaName){
  try{
    const changeStr=(pct>0?'+':'')+((pct||0).toFixed(2))+'%';
    const sector=NMETA[sym]?.s||'Unknown';
    const prompt='You are a stock analysis AI. Given: '+metaName+' ('+sym+') on NSE India. Current price: Rs'+lastPrice+'. Today change: '+changeStr+'. Sector: '+sector+'. Generate a realistic 7-day price forecast as a JSON array of 7 numbers (daily closing prices) starting from tomorrow. Reply with ONLY a JSON array like: [1234.50, 1238.20, 1242.10, 1239.80, 1245.60, 1250.30, 1248.90]. No explanation.';
    const r=await fetch('https://api.groq.com/openai/v1/chat/completions',{
      method:'POST',
      headers:{'Content-Type':'application/json','Authorization':'Bearer '+GROQ},
      body:JSON.stringify({model:'llama-3.1-8b-instant',messages:[{role:'user',content:prompt}],max_tokens:100,temperature:0.4})
    });
    const j=await r.json();
    const text=j.choices?.[0]?.message?.content||'';
    const match=text.match(/\[[\d.,\s]+\]/);
    if(match){
      const arr=JSON.parse(match[0]);
      if(Array.isArray(arr)&&arr.length>=5) return arr.slice(0,7).map(v=>+parseFloat(v).toFixed(2));
    }
  }catch(e){}
  // Fallback: simple momentum-based forecast
  const vol=0.012;
  const momentum=(pct||0)/100;
  const forecast=[];
  let p=lastPrice;
  for(let i=0;i<7;i++){
    p=p*(1+momentum*0.3+(Math.random()-0.48)*vol);
    forecast.push(+p.toFixed(2));
  }
  return forecast;
}

function genLabels(range){
  const pts={'1W':8,'1M':31,'3M':91,'1Y':53}[range]||31;
  const labels=[];
  const now=new Date();
  for(let i=pts-1;i>=0;i--){
    const d=new Date(now);
    d.setDate(d.getDate()-i);
    labels.push(d.toLocaleDateString('en-IN',{month:'short',day:'numeric'}));
  }
  return labels;
}

