// After deploying your worker, replace this URL with your worker URL
// e.g. 'https://stocksense.yourname.workers.dev/api'
const WORKER_URL = 'https://divine-king-acc1.aryan-oleti.workers.dev/api';

let dataSource = 'fallback'; // 'live' or 'fallback'

async function workerFetch(params, timeout=12000){
  const url = new URL(WORKER_URL);
  for(const [k,v] of Object.entries(params)) url.searchParams.set(k,v);
  const r = await fetch(url.toString(), {signal: AbortSignal.timeout(timeout)});
  if(!r.ok) throw new Error(`Worker error: ${r.status}`);
  return r.json();
}

// Map Twelve Data symbol format (RELIANCE:NSE) to our internal format (RELIANCE.NS)
function tdSymToInternal(tdSym){
  return tdSym.replace(':NSE','.NS').replace(':BSE','.NS');
}
// Map internal format to Twelve Data format
function internalToTd(sym){
  return sym.replace('.NS',':NSE');
}

// ===== LIVE FETCH =====
async function fetchLive(){
  const now=Date.now();
  if(now-lastFetch<3*60*60*1000&&lastFetch>0)return;
  lastFetch=now;

  // Build comma-separated Twelve Data symbols for all N50 stocks
  const tdSyms = N50.map(internalToTd).join(',');

  try{
    // Fetch all stock quotes in one call
    const data = await workerFetch({action:'quote', symbols: tdSyms});

    // Twelve Data returns an object keyed by symbol when multiple symbols requested
    const quotes = Array.isArray(data) ? data : Object.values(data);

    quotes.forEach(q=>{
      if(!q || q.status==='error') return;
      // Twelve Data symbol e.g. "RELIANCE:NSE"
      const internalSym = tdSymToInternal(q.symbol);
      if(!FB[internalSym]) return;
      const price = parseFloat(q.close || q.previous_close || 0);
      const change = parseFloat(q.change || 0);
      const changePct = parseFloat(q.percent_change || 0);
      if(price > 0){
        liveStocks[internalSym] = {
          p: +price.toFixed(2),
          c: +change.toFixed(2),
          pct: +changePct.toFixed(2)
        };
      }
    });

    // Fetch index data
    const idxData = await workerFetch({action:'indices'});
    const idxQuotes = Array.isArray(idxData) ? idxData : Object.values(idxData);
    const idxTdMap = {
      'NIFTY:NSE':'nifty50',
      'SENSEX:BSE':'sensex',
      'BANKNIFTY:NSE':'niftybank',
      'CNXIT:NSE':'niftyit'
    };
    idxQuotes.forEach(q=>{
      if(!q || q.status==='error') return;
      const id = idxTdMap[q.symbol];
      if(!id) return;
      const idx = INDICES.find(i=>i.id===id);
      if(!idx) return;
      const price = parseFloat(q.close || q.previous_close || 0);
      const change = parseFloat(q.change || 0);
      const changePct = parseFloat(q.percent_change || 0);
      if(price > 0){
        idx.v = +price.toFixed(2);
        idx.c = +change.toFixed(2);
        idx.p = +changePct.toFixed(2);
      }
    });

    dataSource = 'live';
    showDataBadge('live');

  } catch(e){
    console.warn('Worker fetch failed, using fallback data:', e.message);
    // Fall back to FB static data
    N50.forEach(sym=>{
      if(!liveStocks[sym] && FB[sym]){
        liveStocks[sym]={p:FB[sym].p, c:FB[sym].c, pct:FB[sym].pct};
      }
    });
    dataSource = 'fallback';
    showDataBadge('fallback');
  }
}

function showDataBadge(source){
  const badge = document.getElementById('data-source-badge');
  if(!badge) return;
  if(source==='live'){
