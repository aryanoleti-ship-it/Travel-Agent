<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>StockSense — Live Indian Stocks</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet"/>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
:root{
  --bg:#f4f4ef;--bg2:#fff;--border:#e5e7eb;--text:#111;--text2:#6b7280;--text3:#9ca3af;
  --shadow:rgba(0,0,0,.04);--card-bg:#fff;--input-bg:#fff;--row-hover:#f9fafb;
  --hero-sub:rgba(255,255,255,.55);--chip-border:rgba(255,255,255,.22);--chip-color:rgba(255,255,255,.7);
}
body.dark{
  --bg:#0f1117;--bg2:#1a1d27;--border:#2a2d3a;--text:#e5e7eb;--text2:#9ca3af;--text3:#6b7280;
  --shadow:rgba(0,0,0,.3);--card-bg:#1a1d27;--input-bg:#1a1d27;--row-hover:#22263a;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);transition:background .2s,color .2s}
/* NAV */
nav{background:#1e4a3f;display:flex;align-items:center;justify-content:space-between;padding:0 28px;height:48px;position:sticky;top:0;z-index:200}
.logo{color:#fff;font-weight:800;font-size:15px;letter-spacing:-.3px}
.nav-links{display:flex;gap:2px;align-items:center}
.nav-links button{background:none;border:none;color:rgba(255,255,255,.6);padding:6px 12px;border-radius:6px;cursor:pointer;font-size:12px;font-weight:500;font-family:inherit;transition:all .15s}
.nav-links button:hover{color:#fff;background:rgba(255,255,255,.12)}
.nav-links button.active{color:#fff;background:rgba(255,255,255,.18)}
.nav-buy{background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.3);color:#fff;padding:5px 14px;border-radius:6px;cursor:pointer;font-size:12px;font-weight:600;font-family:inherit}
.nav-buy:hover{background:rgba(255,255,255,.25)}
.nav-right{display:flex;align-items:center;gap:8px}
.nav-badge{border:1px solid rgba(255,255,255,.3);color:rgba(255,255,255,.8);padding:4px 10px;border-radius:6px;font-size:11px;font-weight:600}
.dark-toggle{background:none;border:1px solid rgba(255,255,255,.3);color:rgba(255,255,255,.8);width:30px;height:30px;border-radius:6px;cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;transition:all .15s}
.dark-toggle:hover{background:rgba(255,255,255,.15)}
.nav-user{display:flex;align-items:center;gap:6px;color:rgba(255,255,255,.85);font-size:11px;font-weight:600}
.nav-user-avatar{width:26px;height:26px;border-radius:50%;background:rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff}
.nav-logout{background:none;border:1px solid rgba(255,255,255,.25);color:rgba(255,255,255,.7);padding:3px 8px;border-radius:5px;cursor:pointer;font-size:10px;font-family:inherit}
.nav-logout:hover{background:rgba(255,255,255,.15);color:#fff}
/* PAGES */
.page{display:none}
/* HERO */
.hero{background:linear-gradient(135deg,#1a3a35 0%,#2d6a5e 60%,#1e4a3f 100%);padding:60px 48px 52px;position:relative;overflow:hidden;min-height:380px}
.hero::before{content:'';position:absolute;right:-60px;top:-60px;width:420px;height:420px;border-radius:50%;background:radial-gradient(circle,rgba(74,160,144,.2) 0%,transparent 70%);pointer-events:none}
.hero::after{content:'';position:absolute;right:120px;bottom:-80px;width:280px;height:280px;border-radius:50%;background:radial-gradient(circle,rgba(45,106,94,.3) 0%,transparent 70%);pointer-events:none}
.hero-bull{display:none}


.hero-tag{display:inline-flex;align-items:center;gap:6px;color:rgba(255,255,255,.75);font-size:14px;border:1px solid rgba(255,255,255,.2);border-radius:20px;padding:6px 16px;margin-bottom:22px}
.hero h1{color:#fff;font-size:clamp(2.6rem,5vw,3.8rem);font-weight:900;line-height:1.1;margin-bottom:18px;max-width:580px}
.hero p{color:rgba(255,255,255,.65);font-size:16px;max-width:480px;line-height:1.8;margin-bottom:30px}
.search-box{display:flex;align-items:center;background:#fff;border-radius:10px;max-width:480px;margin-bottom:20px;box-shadow:0 4px 24px rgba(0,0,0,.18);overflow:hidden}
.search-box input{border:none;outline:none;font-size:15px;font-family:inherit;width:100%;color:#111;background:#fff}
.search-box-inner{flex:1;padding:12px 16px}
.search-label{font-size:11px;color:#9ca3af;font-weight:700;text-transform:uppercase;letter-spacing:.08em;margin-bottom:3px}
.search-box input{border:none;outline:none;font-size:15px;font-family:inherit;width:100%;color:#111}
.search-btn{margin:8px;padding:10px 18px;border-radius:8px;background:#2d6a5e;border:none;cursor:pointer;color:#fff;font-size:18px;font-weight:700;transition:background .15s}
.search-btn:hover{background:#1e4a3f}
.hero-chips{display:flex;flex-wrap:wrap;gap:8px}
.hero-chip{padding:6px 14px;border-radius:20px;font-size:13px;font-weight:600;border:1px solid rgba(255,255,255,.22);color:rgba(255,255,255,.8);background:transparent;cursor:pointer;font-family:inherit;transition:all .15s}
.hero-chip:hover{background:rgba(255,255,255,.15);color:#fff}
/* AUTH BANNER */
.auth-banner{background:linear-gradient(90deg,#1e4a3f,#2d6a5e);border-radius:12px;padding:16px 22px;margin:18px 28px 0;display:flex;align-items:center;justify-content:space-between;gap:12px}
.auth-banner-text{color:#fff;font-size:13px;font-weight:600}
.auth-banner-sub{color:rgba(255,255,255,.65);font-size:11px;margin-top:2px}
.auth-banner-btn{background:#fff;color:#1e4a3f;border:none;padding:8px 18px;border-radius:8px;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit;white-space:nowrap;transition:all .15s}
.auth-banner-btn:hover{background:#f0f7f5}
/* INDEX CARDS */
.idx-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;padding:24px 28px 0}
.icard{background:var(--card-bg);border-radius:12px;border:1px solid var(--border);padding:18px 22px;box-shadow:0 1px 4px var(--shadow)}
.iname{font-size:12px;color:var(--text3);font-weight:700;text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px}
.ival{font-size:28px;font-weight:800;color:var(--text);letter-spacing:-.5px}
.ichg{font-size:14px;font-weight:700;margin-top:5px}
.up{color:#16a34a}.dn{color:#dc2626}
/* WRAP */
.wrap{max-width:1100px;margin:0 auto;padding:24px 28px}
/* CARDS */
.card{background:var(--card-bg);border-radius:12px;border:1px solid var(--border);box-shadow:0 1px 4px var(--shadow);padding:20px}
.card-title{font-size:10px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.07em;margin-bottom:14px}
/* GRID */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:18px}
.g3{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:18px}
.g4{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:18px}
/* STOCK ROWS */
.srow{display:grid;grid-template-columns:90px 1fr 90px 70px;align-items:center;padding:10px 16px;border-bottom:1px solid var(--border);cursor:pointer;background:transparent;border-left:none;border-right:none;border-top:none;width:100%;text-align:left;font-family:inherit;transition:background .1s}
.srow:hover{background:var(--row-hover)}
.srow:last-child{border-bottom:none}
.srow .tk{font-weight:700;font-size:12px;color:var(--text)}
.srow .nm{font-size:11px;color:var(--text3);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.srow .pr{font-size:12px;font-weight:600;color:var(--text);text-align:right}
.srow .pc{font-size:12px;font-weight:700;text-align:right}
/* ALL STOCKS */
.stock-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:10px}
.stock-card{background:var(--card-bg);border-radius:10px;border:1px solid var(--border);padding:14px 16px;display:flex;align-items:center;justify-content:space-between;cursor:pointer;transition:all .15s}
.stock-card:hover{border-color:#2d6a5e;box-shadow:0 2px 12px rgba(45,106,94,.1);transform:translateY(-1px)}
.sc-left .tk{font-weight:700;font-size:13px;color:var(--text)}
.sc-left .nm{font-size:10px;color:var(--text3);margin-top:2px}
.sc-right{text-align:right}
.sc-right .pr{font-size:13px;font-weight:700;color:var(--text)}
.sc-right .pc{font-size:11px;font-weight:600;margin-top:2px}
/* DETAIL */
.detail-layout{display:flex;min-height:calc(100vh - 48px)}
.detail-sidebar{width:200px;flex-shrink:0;background:var(--card-bg);border-right:1px solid var(--border);padding:14px;overflow-y:auto;max-height:calc(100vh - 48px)}
.detail-main{flex:1;padding:24px;overflow-y:auto}
.ss-btn{text-align:left;padding:8px 10px;border-radius:8px;cursor:pointer;border:none;background:transparent;width:100%;font-family:inherit;transition:background .1s;margin-bottom:2px}
.ss-btn:hover{background:var(--row-hover)}
.ss-btn.on{background:#2d6a5e}
.ss-btn .st{font-size:11px;font-weight:700;color:var(--text)}
.ss-btn .sn{font-size:10px;color:var(--text3);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.ss-btn.on .st,.ss-btn.on .sn{color:#fff}
.range-btns{display:flex;gap:4px;margin-bottom:16px}
.rb{padding:5px 10px;border-radius:6px;font-size:11px;font-weight:600;border:none;cursor:pointer;background:var(--bg);color:var(--text2);font-family:inherit;transition:all .15s}
.rb.on{background:#2d6a5e;color:#fff}
.krow{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:16px}
.ki .kl{font-size:10px;color:var(--text3);margin-bottom:3px}
.ki .kv{font-size:13px;font-weight:700;color:var(--text)}
.rbar{height:8px;border-radius:4px;background:var(--border);overflow:hidden;margin:8px 0 4px}
.rfill{height:100%;border-radius:4px;transition:width .6s}
.exbox{margin-top:10px;padding:14px;border-radius:10px;background:var(--row-hover);border:1px solid var(--border);font-size:12px;color:var(--text2);line-height:1.7;display:none}
.exbox.show{display:block}
.disclaimer{background:#fffbeb;border:1px solid #fde68a;border-radius:10px;padding:12px 16px;font-size:11px;color:#92400e;line-height:1.6;margin-top:14px}
.disclaimer strong{color:#78350f}
/* PORTFOLIO */
.port-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:18px}
.pstat{background:var(--card-bg);border-radius:12px;border:1px solid var(--border);padding:14px 18px}
.pstat .pl{font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:5px}
.pstat .pv{font-size:20px;font-weight:800;color:var(--text)}
.ptbl-head{display:grid;grid-template-columns:90px 1fr 100px 100px 120px;padding:8px 18px;font-size:10px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;border-bottom:1px solid var(--border)}
.prow{display:grid;grid-template-columns:90px 1fr 100px 100px 120px;align-items:center;padding:10px 18px;border-bottom:1px solid var(--border);transition:background .1s}
.prow:hover{background:var(--row-hover)}
/* GLOSSARY */
.gloss-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
.gc{background:var(--card-bg);border-radius:10px;border:1px solid var(--border);padding:14px;transition:box-shadow .15s}
.gc:hover{box-shadow:0 4px 14px var(--shadow)}
.gt{font-weight:700;font-size:12px;color:var(--text);margin-bottom:5px}
.gd{font-size:11px;color:var(--text2);line-height:1.6}
/* NEWS */
.ni{padding:18px 22px;border-bottom:1px solid var(--border);display:flex;gap:12px}
.ni:last-child{border-bottom:none}
.ndot{width:8px;height:8px;border-radius:50%;margin-top:5px;flex-shrink:0}
.ntit{font-weight:600;font-size:13px;color:var(--text);margin-bottom:3px;line-height:1.4}
.nsrc{font-size:11px;color:var(--text3);margin-bottom:5px}
.nsum{font-size:11px;color:var(--text2);margin-bottom:6px;line-height:1.6}
.nwhy{font-size:11px;color:#2d6a5e;font-weight:600;margin-bottom:6px}
.tag{font-size:10px;font-weight:600;padding:2px 8px;border-radius:20px;display:inline-block}
.tp{background:#dcfce7;color:#166534}.tn{background:#fee2e2;color:#991b1b}.tne{background:#dbeafe;color:#1e40af}.tm{background:#fef9c3;color:#854d0e}
/* AI CHAT */
.chat-wrap{display:flex;gap:16px}
.chat-qs{width:200px;flex-shrink:0}
.qq{text-align:left;padding:8px 12px;border-radius:8px;border:1px solid var(--border);background:var(--card-bg);font-size:11px;color:var(--text2);cursor:pointer;width:100%;margin-bottom:6px;font-family:inherit;transition:all .15s}
.qq:hover{border-color:#2d6a5e;background:var(--row-hover)}
.chat-win{flex:1;background:var(--card-bg);border-radius:12px;border:1px solid var(--border);display:flex;flex-direction:column;height:520px}
.chat-hdr{padding:10px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px}
.chat-dot{width:8px;height:8px;border-radius:50%;background:#16a34a}
.chat-title{font-size:10px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:.07em}
.chat-msgs{flex:1;padding:16px;overflow-y:auto}
.mrow{display:flex;margin-bottom:14px}
.mrow.u{justify-content:flex-end}
.av{width:28px;height:28px;border-radius:50%;background:#2d6a5e;color:#fff;font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center;margin-right:8px;flex-shrink:0;margin-top:2px}
.bai{background:var(--row-hover);border:1px solid var(--border);border-radius:12px 12px 12px 2px;padding:10px 14px;font-size:12px;line-height:1.7;max-width:480px;color:var(--text)}
.bu{background:#2d6a5e;color:#fff;border-radius:12px 12px 2px 12px;padding:10px 14px;font-size:12px;line-height:1.7;max-width:480px}
.chat-inp{border-top:1px solid var(--border);padding:10px 14px;display:flex;align-items:center;gap:8px}
.chat-inp input{flex:1;border:none;font-size:12px;color:var(--text);background:transparent;outline:none;font-family:inherit}
/* BUY */
.broker-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.bcard{background:var(--card-bg);border-radius:14px;border:1px solid var(--border);padding:22px;box-shadow:0 2px 8px var(--shadow);transition:all .2s;text-decoration:none;display:block}
.bcard:hover{box-shadow:0 8px 28px rgba(45,106,94,.14);transform:translateY(-2px);border-color:#2d6a5e}
.blogo{font-size:28px;margin-bottom:10px}
.bname{font-size:16px;font-weight:800;color:var(--text);margin-bottom:3px}
.btag{font-size:10px;font-weight:600;padding:2px 9px;border-radius:20px;background:#f0f7f5;color:#2d6a5e;display:inline-block;margin-bottom:10px}
.bdesc{font-size:12px;color:var(--text2);line-height:1.6;margin-bottom:14px}
.bfeats{display:flex;flex-direction:column;gap:5px;margin-bottom:14px}
.bfeat{font-size:11px;color:var(--text2);display:flex;align-items:center;gap:5px}
.bfeat::before{content:'✓';color:#16a34a;font-weight:700}
.bbtn{display:block;text-align:center;background:#2d6a5e;color:#fff;padding:9px;border-radius:8px;font-size:12px;font-weight:600;text-decoration:none;transition:background .15s}
.bbtn:hover{background:#1e4a3f}
.steps{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:28px}
.step{background:var(--card-bg);border-radius:12px;border:1px solid var(--border);padding:18px;text-align:center}
.snum{width:36px;height:36px;border-radius:50%;background:#2d6a5e;color:#fff;font-size:15px;font-weight:800;display:flex;align-items:center;justify-content:center;margin:0 auto 10px}
.stit{font-size:13px;font-weight:700;color:var(--text);margin-bottom:5px}
.sdesc{font-size:11px;color:var(--text2);line-height:1.5}
/* BUTTONS */
.btn{background:#2d6a5e;color:#fff;border:none;padding:9px 20px;border-radius:8px;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;transition:background .15s}
.btn:hover{background:#1e4a3f}
.btn-outline{background:transparent;color:#2d6a5e;border:1.5px solid #2d6a5e;padding:7px 14px;border-radius:8px;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;transition:all .15s}
.btn-outline:hover{background:var(--row-hover)}
/* SPINNER */
.spin{display:flex;align-items:center;justify-content:center;padding:60px;flex-direction:column;gap:10px;color:var(--text3);font-size:12px}
.sp{width:28px;height:28px;border:3px solid var(--border);border-top-color:#2d6a5e;border-radius:50%;animation:sp .8s linear infinite}
@keyframes sp{to{transform:rotate(360deg)}}
/* SCROLLBAR */
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:#d1d5db;border-radius:4px}
/* INPUTS */
input,select{background:var(--input-bg);color:var(--text);border-color:var(--border)}
input::placeholder{color:var(--text3)}
input:focus{outline:none}
h1{font-size:22px;font-weight:800;color:var(--text);margin-bottom:4px}
.sub{font-size:13px;color:var(--text3);margin-bottom:20px}
/* AUTH PANEL */
.auth-overlay{position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:1100;display:none;backdrop-filter:blur(2px)}
.auth-overlay.open{display:block}
.auth-panel{position:fixed;top:0;right:-420px;width:400px;height:100vh;background:var(--card-bg);border-left:1px solid var(--border);z-index:1101;display:flex;flex-direction:column;transition:right .3s cubic-bezier(.4,0,.2,1);box-shadow:-8px 0 32px rgba(0,0,0,.15);overflow-y:auto}
.auth-panel.open{right:0}
.auth-panel-header{padding:24px 24px 0;display:flex;align-items:center;justify-content:space-between}
.auth-panel-logo{font-size:16px;font-weight:800;color:#2d6a5e}
.auth-close{background:none;border:1px solid var(--border);color:var(--text2);width:32px;height:32px;border-radius:8px;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center}
.auth-close:hover{background:var(--row-hover)}
.auth-tabs{display:flex;gap:0;margin:20px 24px 0;border-bottom:1px solid var(--border)}
.auth-tab{flex:1;padding:10px;text-align:center;font-size:13px;font-weight:600;color:var(--text3);cursor:pointer;border-bottom:2px solid transparent;transition:all .15s;background:none;border-top:none;border-left:none;border-right:none;font-family:inherit}
.auth-tab.active{color:#2d6a5e;border-bottom-color:#2d6a5e}
.auth-body{padding:24px}
.auth-field{margin-bottom:14px}
.auth-label{font-size:11px;font-weight:600;color:var(--text2);margin-bottom:5px;display:block}
.auth-input{width:100%;padding:10px 12px;border:1px solid var(--border);border-radius:8px;font-size:13px;font-family:inherit;background:var(--input-bg);color:var(--text);transition:border .15s}
.auth-input:focus{outline:none;border-color:#2d6a5e}
.auth-submit{width:100%;padding:11px;background:#2d6a5e;color:#fff;border:none;border-radius:8px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;margin-top:4px;transition:background .15s}
.auth-submit:hover{background:#1e4a3f}
.auth-divider{display:flex;align-items:center;gap:10px;margin:16px 0;color:var(--text3);font-size:11px}
.auth-divider::before,.auth-divider::after{content:'';flex:1;height:1px;background:var(--border)}
.auth-google{width:100%;padding:10px;background:var(--bg);border:1px solid var(--border);border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;color:var(--text);display:flex;align-items:center;justify-content:center;gap:8px;transition:all .15s}
.auth-google:hover{border-color:#2d6a5e;background:var(--row-hover)}
.auth-error{font-size:11px;color:#dc2626;margin-top:6px;display:none}
.auth-error.show{display:block}
.auth-success{font-size:11px;color:#16a34a;margin-top:6px;display:none}
.auth-success.show{display:block}
/* LANDING PAGE */
.landing-overlay{position:fixed;inset:0;z-index:1000;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#1a3a35 0%,#2d6a5e 60%,#1e4a3f 100%)}
.landing-overlay.hidden{display:none}
.landing-blur{position:fixed;inset:0;z-index:999;backdrop-filter:blur(8px);background:rgba(0,0,0,0.45);pointer-events:all}
.landing-blur.hidden{display:none}
.landing-card{text-align:center;padding:48px 56px;max-width:520px;width:90%}
.landing-tag{display:inline-flex;align-items:center;gap:6px;color:rgba(255,255,255,.75);font-size:13px;border:1px solid rgba(255,255,255,.2);border-radius:20px;padding:6px 16px;margin-bottom:24px}
