  nws.innerHTML=`<div class="spin"><div class="sp"></div>Loading live news...</div>`;

  try{
    const data = await workerFetch({action:'news', symbol:'NIFTY'}, 10000);
    const items = data.items || [];

    if(!items.length) throw new Error('No news items');

    nws.innerHTML = items.map((n,i)=>{
      const date = n.pubDate ? new Date(n.pubDate).toLocaleDateString('en-IN',{month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) : '';
      // Simple sentiment: positive words → green, negative → red
      const title = n.title || '';
      const isPos = /gain|rise|surge|up|high|bull|growth|profit|record|rally/i.test(title);
      const isNeg = /fall|drop|crash|down|low|bear|loss|decline|sell|weak/i.test(title);
      const dot = isPos ? '#16a34a' : isNeg ? '#dc2626' : '#3b82f6';
      const tagCls = isPos ? 'tp' : isNeg ? 'tn' : 'tne';
      const tagLbl = isPos ? 'Positive' : isNeg ? 'Negative' : 'Neutral';
      const desc = n.description || '';
      const link = n.link || '#';

      return `<div class="ni" style="flex-direction:column">
        <div style="display:flex;gap:12px;align-items:flex-start">
          <div class="ndot" style="background:${dot};margin-top:5px;flex-shrink:0"></div>
          <div style="flex:1">
            <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;flex-wrap:wrap">
              <a class="ntit" href="${link}" target="_blank" rel="noopener" style="flex:1;text-decoration:none;color:var(--text)">${title}</a>
            </div>
            <div style="display:flex;align-items:center;gap:10px;margin-top:3px;flex-wrap:wrap">
              <span class="nsrc" style="margin:0">Yahoo Finance</span>
              ${date?`<span style="font-size:10px;color:var(--text3)">🕐 ${date}</span>`:''}
              <span class="tag ${tagCls}">${tagLbl}</span>
            </div>
            ${desc?`<div class="nsum" style="margin-top:6px">${desc}</div>`:''}
          </div>
        </div>
      </div>`;
    }).join('');

  } catch(e){
    // Fallback to static news if worker fails
    nws.innerHTML=NEWS.map((n,i)=>`
      <div class="ni" style="flex-direction:column;cursor:pointer" onclick="toggleNews(${i})">
        <div style="display:flex;gap:12px;align-items:flex-start">
          <div class="ndot" style="background:${n.dot};margin-top:5px;flex-shrink:0"></div>
          <div style="flex:1">
            <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;flex-wrap:wrap">
              <div class="ntit" style="flex:1">${n.t}</div>
              <span id="news-arrow-${i}" style="font-size:12px;color:var(--text3);flex-shrink:0;transition:transform .2s">▼</span>
            </div>
            <div style="display:flex;align-items:center;gap:10px;margin-top:3px;flex-wrap:wrap">
              <span class="nsrc" style="margin:0">${n.src}</span>
              <span style="font-size:10px;color:var(--text3)">🕐 ${n.date}</span>
              <span class="tag ${n.tag}">${n.tl}</span>
            </div>
            <div class="nsum" style="margin-top:6px">${n.sum}</div>
          </div>
        </div>
        <div id="news-expand-${i}" style="display:none;margin-top:12px;margin-left:20px;padding:14px;background:var(--row-hover);border-radius:10px;border:1px solid var(--border)">
          <div class="nwhy" style="margin-bottom:8px">💡 <strong>Why it matters:</strong> ${n.why}</div>
          <div style="font-size:12px;color:var(--text2);line-height:1.7">${n.more}</div>
        </div>
      </div>
    `).join('');
  }
}
function toggleNews(i){
  const el=document.getElementById('news-expand-'+i);
  const arrow=document.getElementById('news-arrow-'+i);
  if(!el)return;
  const open=el.style.display==='block';
  el.style.display=open?'none':'block';
  if(arrow)arrow.style.transform=open?'':'rotate(180deg)';
}

// ===== AI CHAT =====
function initChat(){
  const cm=document.getElementById('cm');
  if(!cm)return;
  if(cm.children.length) return; // already rendered
  // Restore saved chat history
  if(chatHist.length){
    chatHist.forEach(m=>addMsg(m.role==='user'?'user':'ai',m.content));
  } else {
    addMsg('ai','👋 Hi! I\'m StockSense AI, powered by Groq. Ask me anything about investing in India — stocks, mutual funds, SIP, brokers, or market concepts!');
  }
}
function addMsg(role,text){
  const cm=document.getElementById('cm');
  if(!cm)return;
  const div=document.createElement('div');
  div.className='mrow'+(role==='user'?' u':'');
  if(role==='ai'){
    div.innerHTML=`<div class="av">AI</div><div class="bai">${text}</div>`;
  } else {
    div.innerHTML=`<div class="bu">${text}</div>`;
  }
  cm.appendChild(div);
  cm.scrollTop=cm.scrollHeight;
}
async function sc(preset){
  const inp=document.getElementById('ci');
  const msg=preset||(inp?.value||'').trim();
  if(!msg)return;
  if(inp)inp.value='';
  addMsg('user',msg);
  chatHist.push({role:'user',content:msg});
  saveChatHist();
  const btn=document.getElementById('csend');
  if(btn){btn.disabled=true;btn.textContent='...';}
  try{
    const r=await fetch('https://api.groq.com/openai/v1/chat/completions',{
      method:'POST',
      headers:{'Content-Type':'application/json','Authorization':'Bearer '+GROQ},
      body:JSON.stringify({
        model:'llama-3.1-8b-instant',
        messages:[
          {role:'system',content:'You are StockSense AI, a friendly investing assistant for Indian retail investors. Keep answers concise (2-4 sentences), use simple language, and focus on Indian markets (NSE, BSE, Nifty, Sensex). Always add a disclaimer that you are not a financial advisor.'},
          ...chatHist.slice(-8)
        ],
        max_tokens:300,temperature:0.7
      })
    });
    const j=await r.json();
    if(!r.ok){
      addMsg('ai','⚠ API Error '+r.status+': '+(j.error?.message||JSON.stringify(j)));
    } else {
      const reply=j.choices?.[0]?.message?.content||'Sorry, I could not get a response. Please try again.';
      chatHist.push({role:'assistant',content:reply});
      saveChatHist();
      addMsg('ai',reply);
    }
  }catch(e){
    addMsg('ai','⚠ Error: '+e.message);
  }
  if(btn){btn.disabled=false;btn.textContent='Send →';}
}

// ===== LANDING PAGE =====
function showLanding(){
  document.getElementById('landingOverlay').classList.remove('hidden');
  document.getElementById('landingBlur').classList.remove('hidden');
  document.body.style.overflow='hidden';
}
function hideLanding(){
  document.getElementById('landingOverlay').classList.add('hidden');
  document.getElementById('landingBlur').classList.add('hidden');
  document.body.style.overflow='';
}
function landingSignIn(){
  openAuth('signin');
}
function landingSignUp(){
  openAuth('signup');
}

async function startApp(){
  hideLanding();
  // Load user-specific portfolio and chat data
  loadUserData();
  document.getElementById('p-home').style.display='block';
  document.getElementById('n-home').classList.add('active');
  updateNavUser();
  updateAuthBanner();
  await fetchLive();
  renderHome();
  // Refresh every 3 hours
  setInterval(async()=>{
    lastFetch=0;
    // Clear historical chart cache so fresh data is fetched
    Object.keys(histCache).forEach(k=>delete histCache[k]);
    await fetchLive();
    const activePage=document.querySelector('.page[style*="block"]');
    if(activePage){
      const id=activePage.id.replace('p-','');
      if(id==='home')renderHome();
      else if(id==='market')renderMarket();
      else if(id==='all')fas();
      else if(id==='detail')renderDetail();
    }
  },3*60*60*1000);
}

// ===== INIT =====
async function init(){
  initDark();
  const user=getCurrentUser();
  if(user){
    // Already logged in — go straight to app
    await startApp();
  } else {
    // Show landing page
    showLanding();
  }
}
window.addEventListener('DOMContentLoaded',init);
</script>
